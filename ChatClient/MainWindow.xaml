<Window x:Class="ChatClient.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Chat App" Height="600" Width="850" Background="#313338">
    <Window.Resources>
        <!-- Gomb -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#5865F2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#404249"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <!-- ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#383A40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <!-- ListBox elem -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        <!-- Text -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="MessageBubbleStyle"
       TargetType="Border">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="MaxWidth" Value="350"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#404249"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- HEADER -->
        <Border Grid.Row="0" Background="#2B2D31" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💬 Chat Client"
                FontSize="22"
                FontWeight="Bold"
                VerticalAlignment="Center"
                Margin="0,0,30,0"/>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Username"
                    FontSize="12"
                    Margin="0,0,0,5"/>
                    <TextBox x:Name="UsernameBox"
                    Width="180"
                    Height="35"
                    Margin="0,0,0,5"/>
                    <TextBlock Text="Password"
                    FontSize="12"
                    Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox"
                    Width="180"
                    Height="35"
                    Margin="0,0,0,5"/>
                </StackPanel>
                <Button Content="Login"
                Width="100"
                Height="35"
                VerticalAlignment="Center"
                Margin="10,0,0,0"
                Click="Login_Click"/>
            </StackPanel>
        </Border>
        <!-- MAIN AREA -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- USERS -->
            <Border Grid.Column="0" Background="#2B2D31" CornerRadius="10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Online users" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ListBox x:Name="UsersList" Background="#2B2D31" SelectionChanged="UsersList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#3B3D43" CornerRadius="8" Padding="8" Margin="0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Avatar -->
                                        <Ellipse Width="35"
                                        Height="35"
                                        Fill="#5865F2"
                                        VerticalAlignment="Center"/>
                                        <!-- Online jel -->
                                        <Ellipse Width="10"
                                        Height="10"
                                        Fill="LimeGreen"
                                        VerticalAlignment="Bottom"
                                        Margin="-10,0,8,0"/>
                                        <!-- Username -->
                                        <TextBlock Text="{Binding Username}"
                                        FontSize="15"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
            <!-- CHAT -->
            <Border Grid.Column="2"
            Background="#383A40"
            CornerRadius="10"
            Padding="10">
            <DockPanel>
            <!-- Beszélgetés fejléc -->
                <Border DockPanel.Dock="Top"
                Background="#2B2D31"
                Padding="12"
                CornerRadius="8"
                Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock
                            x:Name="ChatTitle"
                            FontSize="18"
                            FontWeight="Bold"/>
                            <TextBlock
                            Text="Online"
                            Foreground="LightGreen"/>
                        </StackPanel>
                    </Border>
                    <!-- Üzenetek -->
                    <ListBox x:Name="MessagesList"
                    Background="#383A40">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border
                                Padding="10"
                                Margin="5"
                                CornerRadius="12"
                                MaxWidth="350"
                                Background="#444654">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="HorizontalAlignment"
                                            Value="Left"/>
                                            <Setter Property="Background"
                                            Value="#444654"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMine}"
                                                 Value="True">
                                                    <Setter Property="HorizontalAlignment"
                                                    Value="Right"/>
                                                    <Setter Property="Background"
                                                    Value="#5865F2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Profilkép -->
                                        <Ellipse Width="40"
                                        Height="40"
                                        Fill="#5865F2"
                                        VerticalAlignment="Top"/>
                                        <StackPanel Margin="10,0,0,0"
                                        VerticalAlignment="Top">
                                            <!-- Név -->
                                            <TextBlock Text="{Binding User}"
                                            FontWeight="Bold"/>
                                            <!-- Üzenet -->
                                            <TextBlock Text="{Binding Text}"
                                            TextWrapping="Wrap"/>
                                            <!-- Csatolmány -->
                                            <StackPanel Margin="0,5,0,0">
                                                <!-- Kép megjelenítése -->
                                                <Image Source="{Binding FileUrl}"
                                                Width="200"
                                                MaxHeight="200"
                                                Stretch="Uniform"
                                                VerticalAlignment="Top"
                                                Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibilityConverter}}"
                                                MouseDown="Image_Click"/>
                                                <Button Content="⬇ Download"
                                                Tag="{Binding FileUrl}"
                                                Click="Download_Click"
                                                Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <!-- Nem kép fájl esetén link -->
                                                <TextBlock Text="{Binding FileUrl}"
                                                TextWrapping="Wrap"
                                                Foreground="LightBlue"
                                                Cursor="Hand"
                                                MouseDown="File_Click">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsImage}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <!-- Idő -->
                                            <TextBlock Text="{Binding Time}"
                                            FontSize="10"
                                            HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
        <!-- MESSAGE INPUT -->
        <Border Grid.Row="2" Background="#2B2D31" CornerRadius="10" Margin="0,10,0,0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <Button Content="📎 Open file"
                Tag="{Binding FileUrl}"
                Click="Attach_Click"/>
                <TextBox Grid.Column="1"
                x:Name="MessageInput"
                KeyDown="MessageInput_KeyDown"/>
                <Button Grid.Column="2"
                Content="➤"
                Click="Send_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>