<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat App"
        Height="600"
        Width="850"
        Background="#ECEFF4">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4F8EF7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💬 Chat Client"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="UsernameBox"
                         Width="180"
                         Margin="30,0,0,0"/>
                <Button Content="Login"
                        Width="100"
                        Click="Login_Click"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="Online users"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,10"/>
                    <ComboBox x:Name="UsersList"
                              DisplayMemberPath="Username"
                              SelectionChanged="UsersList_SelectionChanged"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="10"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="Conversation"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,10"/>
                    <ListBox x:Name="MessagesList"/>
                </StackPanel>
            </Border>
        </Grid>
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Margin="0,10,0,0"
                Padding="10">
            <DockPanel>
                <Button Content="Send"
                        Width="100"
                        DockPanel.Dock="Right"
                        Click="Send_Click"/>
                <TextBox x:Name="MessageInput"
                         Margin="0,0,10,0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>